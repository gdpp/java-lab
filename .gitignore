# ============================================================
#  .gitignore — Java · Spring Boot · Maven
# ============================================================

# ──────────────────────────────────────────────────────────────
#  Compilados y artefactos de build
# ──────────────────────────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

*.class
*.jar
*.war
*.ear
*.nar
*.sar
*.zip
*.tar.gz
*.rar

# ──────────────────────────────────────────────────────────────
#  Maven
# ──────────────────────────────────────────────────────────────
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.properties
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties

# ──────────────────────────────────────────────────────────────
#  Logs
# ──────────────────────────────────────────────────────────────
*.log
*.log.*
logs/
log/
spring.log

# ──────────────────────────────────────────────────────────────
#  Spring Boot
# ──────────────────────────────────────────────────────────────
spring-shell.log
*.pid

# Archivos de configuración con secretos — ignorar variantes locales
application-local.properties
application-local.yml
application-secret*.properties
application-secret*.yml
*.env
.env
.env.*

# ──────────────────────────────────────────────────────────────
#  IDEs — IntelliJ IDEA
# ──────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# ──────────────────────────────────────────────────────────────
#  IDEs — Eclipse / STS (Spring Tool Suite)
# ──────────────────────────────────────────────────────────────
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
bin/

# ──────────────────────────────────────────────────────────────
#  IDEs — VS Code
# ──────────────────────────────────────────────────────────────
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ──────────────────────────────────────────────────────────────
#  IDEs — NetBeans
# ──────────────────────────────────────────────────────────────
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
nbactions.xml

# ──────────────────────────────────────────────────────────────
#  Sistema Operativo
# ──────────────────────────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# ──────────────────────────────────────────────────────────────
#  Cobertura y calidad de código
# ──────────────────────────────────────────────────────────────
*.exec
jacoco.exec
jacoco/
coverage/
.sonar/
.scannerwork/
checkstyle-result.xml
pmd.xml
spotbugs/

# ──────────────────────────────────────────────────────────────
#  Docker
# ──────────────────────────────────────────────────────────────
.dockerignore
docker-compose.override.yml

# ──────────────────────────────────────────────────────────────
#  Kubernetes / Helm
# ──────────────────────────────────────────────────────────────
*.kubeconfig
values-local.yaml
values-secret.yaml

# ──────────────────────────────────────────────────────────────
#  Bases de datos embebidas
# ──────────────────────────────────────────────────────────────
*.db
*.sqlite
*.h2.mv.db
*.h2.trace.db
data.mv.db
data.trace.db

# ──────────────────────────────────────────────────────────────
#  Terraform / Infraestructura
# ──────────────────────────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars

# ──────────────────────────────────────────────────────────────
#  Node / Frontend (si el proyecto tiene módulo frontend)
# ──────────────────────────────────────────────────────────────
node_modules/
dist/
.npm
.yarn/cache

# ──────────────────────────────────────────────────────────────
#  Temporales y misc
# ──────────────────────────────────────────────────────────────
*.tmp
*.temp
*.swp
*.swo
*.orig
*.bak
*.rej
HELP.md
